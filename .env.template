# MuDiPA environment configuration — copy to .env and fill in your own values.
# (Do NOT commit .env; it is gitignored.)

# Claude reasoning engine (optional). Provide ONE of:
#  - CLAUDE_CODE_OAUTH_TOKEN: a Claude CLI OAuth token, or
#  - ANTHROPIC_API_KEY:       an Anthropic API key.
# Without either, the reasoning engine is disabled and the tool still runs
# (suggestion engine + manual annotation).
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=

# Shared study login password (default: catan-study).
MUDIPA_STUDY_PASSWORD=catan-study

# Flask session secret. Set a real random value in production.
MUDIPA_SECRET_KEY=

# Hugging Face token for the suggestion_engine base-model download (parser only).
HF_TOKEN=
